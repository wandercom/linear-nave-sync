# Copy to .env and fill in, then `source .env` (or export these in your shell profile).

# Linear personal API key. Create at: Linear > Settings > Security & access > API.
# Used verbatim in the Authorization header (NO "Bearer " prefix).
LINEAR_API_KEY=lin_api_xxxxxxxxxxxxxxxxxxxx

# The Linear team to pull, by team KEY (the issue-id prefix, e.g. WOS for WOS-1234).
LINEAR_TEAM_KEY=WOS

# Nave API token. In Nave: dashboard > API > "Get Access Token".
# Also used verbatim in the Authorization header (NO "Bearer " prefix).
NAVE_TOKEN=xxxxxxxxxxxxxxxxxxxx

# Target Nave dashboard id (can also be passed with --dashboard-id).
NAVE_DASHBOARD_ID=xxxxxxxxxxxxxxxxxxxx
